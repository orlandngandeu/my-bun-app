{
	"name": "my-bun-app",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun --hot run index.ts",
		"start": "bun run index.ts",
		"start:prod": "bun run dist/index.js",
		"build": "bun build index.ts --outdir ./dist --target bun",
		"format": "biome format . --write",
		"lint": "biome check .",
		"test": "bun test"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "^1.3.11",
		"@types/figlet": "^1.7.0"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"figlet": "^1.11.0"
	}
}
